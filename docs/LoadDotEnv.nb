Cell[CellGroupData[{

Cell["Details & Options", "Subsection",
 Editable->False,
 Deletable->False,
 CellTags->{"Details & Options"},
 CellID->100000014,ExpressionUUID->"a1000001-0001-0001-0001-000000000014"],

Cell["\<\
LoadDotEnv parses KEY=VALUE pairs, ignoring comment lines (starting with #) \
and blank lines.\
\>", "Notes",
 CellID->100000015,ExpressionUUID->"a1000001-0001-0001-0001-000000000015"],

Cell["\<\
Double-quote characters around values are stripped.\
\>", "Notes",
 CellID->100000016,ExpressionUUID->"a1000001-0001-0001-0001-000000000016"],

Cell["\<\
The function returns $Failed with a message if the file is not found, and an \
empty <||> if the file contains no valid entries.\
\>", "Notes",
 CellID->100000017,ExpressionUUID->"a1000001-0001-0001-0001-000000000017"],

Cell["\<\
No options are available.\
\>", "Notes",
 CellID->100000018,ExpressionUUID->"a1000001-0001-0001-0001-000000000018"]

}, Open  ]],

Cell[CellGroupData[{

Cell["Examples", "Section",
 Editable->False,
