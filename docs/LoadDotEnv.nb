 CellTags->{"Examples"},
 CellID->100000019,ExpressionUUID->"a1000001-0001-0001-0001-000000000019"],

Cell[CellGroupData[{

Cell["Basic Examples", "Subsection",
 CellID->100000020,ExpressionUUID->"a1000001-0001-0001-0001-000000000020"],

Cell["Write and load a simple .env file:", "Text",
 CellID->100000021,ExpressionUUID->"a1000001-0001-0001-0001-000000000021"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"file", "=",
   RowBox[{"Export", "[",
    RowBox[{
     RowBox[{"FileNameJoin", "[",
      RowBox[{"{",
       RowBox[{"$TemporaryDirectory", ",", "\"\<.env\>\""}], "}"}],
      "]"}], ",",
     "\"\<API_KEY=abc123\nDB_HOST=localhost\>\"", ",",
     "\"\<Text\>\""}], "]"}]}], ";",
  RowBox[{"LoadDotEnv", "[", "file", "]"}]}]], "Input",
 CellLabel->"In[1]:=",
 CellID->100000022,ExpressionUUID->"a1000001-0001-0001-0001-000000000022"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]",
  RowBox[{
   "\"\<API_KEY\>\"", "\[Rule]", "\"\<abc123\>\"", ",",
   "\"\<DB_HOST\>\"", "\[Rule]", "\"\<localhost\>\""}],
  "\[RightAssociation]"}]], "Output",
 CellLabel->"Out[1]=",
 CellID->100000023,ExpressionUUID->"a1000001-0001-0001-0001-000000000023"]

}, Open  ]],

Cell["Load a file with comments and blank lines:", "Text",
 CellID->100000024,ExpressionUUID->"a1000001-0001-0001-0001-000000000024"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"file", "=",
   RowBox[{"Export", "[",
    RowBox[{
     RowBox[{"FileNameJoin", "[",
      RowBox[{"{",
       RowBox[{"$TemporaryDirectory", ",", "\"\<.env\>\""}], "}"}],
      "]"}], ",",
     "\"\<# database config\nDB_HOST=localhost\n\nDB_PORT=5432\>\"", ",",
     "\"\<Text\>\""}], "]"}]}], ";",
  RowBox[{"LoadDotEnv", "[", "file", "]"}]}]], "Input",
 CellLabel->"In[2]:=",
 CellID->100000025,ExpressionUUID->"a1000001-0001-0001-0001-000000000025"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]",
  RowBox[{
   "\"\<DB_HOST\>\"", "\[Rule]", "\"\<localhost\>\"", ",",
   "\"\<DB_PORT\>\"", "\[Rule]", "\"\<5432\>\""}],
  "\[RightAssociation]"}]], "Output",
 CellLabel->"Out[2]=",
 CellID->100000026,ExpressionUUID->"a1000001-0001-0001-0001-000000000026"]

}, Open  ]],

Cell["Quoted values have quotes stripped:", "Text",
 CellID->100000027,ExpressionUUID->"a1000001-0001-0001-0001-000000000027"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"file", "=",
   RowBox[{"Export", "[",
    RowBox[{
     RowBox[{"FileNameJoin", "[",
      RowBox[{"{",
       RowBox[{"$TemporaryDirectory", ",", "\"\<.env\>\""}], "}"}],
      "]"}], ",",
     "\"\<SECRET=\\\"my secret value\\\"\>\"", ",",
     "\"\<Text\>\""}], "]"}]}], ";",
  RowBox[{"LoadDotEnv", "[", "file", "]"}]}]], "Input",
 CellLabel->"In[3]:=",
 CellID->100000028,ExpressionUUID->"a1000001-0001-0001-0001-000000000028"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]",
  RowBox[{"\"\<SECRET\>\"", "\[Rule]", "\"\<my secret value\>\""}],
  "\[RightAssociation]"}]], "Output",
 CellLabel->"Out[3]=",
 CellID->100000029,ExpressionUUID->"a1000001-0001-0001-0001-000000000029"]

}, Open  ]]

}, Open  ]],

Cell[CellGroupData[{

Cell["Scope", "Subsection",
 CellID->100000030,ExpressionUUID->"a1000001-0001-0001-0001-000000000030"],

Cell["\<\
Use the zero-argument form to load the .env file from the current directory:\
\>", "Text",
 CellID->100000031,ExpressionUUID->"a1000001-0001-0001-0001-000000000031"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"SetDirectory", "[", "$TemporaryDirectory", "]"}], ";",
  RowBox[{"Export", "[",
   RowBox[{"\"\<.env\>\"", ",", "\"\<FOO=bar\>\"", ",", "\"\<Text\>\""}],
   "]"}], ";",
  RowBox[{"LoadDotEnv", "[", "]"}]}]], "Input",
 CellLabel->"In[4]:=",
 CellID->100000032,ExpressionUUID->"a1000001-0001-0001-0001-000000000032"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]",
  RowBox[{"\"\<FOO\>\"", "\[Rule]", "\"\<bar\>\""}],
  "\[RightAssociation]"}]], "Output",
 CellLabel->"Out[4]=",
 CellID->100000033,ExpressionUUID->"a1000001-0001-0001-0001-000000000033"]

}, Open  ]],

Cell[BoxData[
 RowBox[{"ResetDirectory", "[", "]"}]], "Input",
