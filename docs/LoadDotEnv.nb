Notebook[{

Cell["LoadDotEnv", "Title",
 Deletable->False,
 CellTags->{"Name", "Title"},
 CellID->100000001,ExpressionUUID->"a1000001-0001-0001-0001-000000000001"],

Cell["Load environment variables from a .env file and return them as an \
Association", "Text",
 Deletable->False,
 CellTags->{"Description"},
 CellID->100000002,ExpressionUUID->"a1000001-0001-0001-0001-000000000002"],

Cell[CellGroupData[{

Cell["Definition", "Section",
 Editable->False,
 Deletable->False,
 CellTags->{"Definition"},
 CellID->100000003,ExpressionUUID->"a1000001-0001-0001-0001-000000000003"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LoadDotEnv", "::", "usage"}], "=",
  "\"\<LoadDotEnv[] loads the .env file in the current working directory and \
returns an Association of key-value pairs.\nLoadDotEnv[path] loads the .env \
file at the given path.\>\""}]], "Input",
 CellID->100000004,ExpressionUUID->"a1000001-0001-0001-0001-000000000004"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LoadDotEnv", "[", "]"}], ":=",
  RowBox[{"LoadDotEnv", "[",
   RowBox[{"FileNameJoin", "[",
    RowBox[{"{",
     RowBox[{
      RowBox[{"Directory", "[", "]"}], ",", "\"\<.env\>\""}], "}"}],
    "]"}], "]"}]}]], "Input",
 CellID->100000005,ExpressionUUID->"a1000001-0001-0001-0001-000000000005"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LoadDotEnv", "[",
   RowBox[{"path_", "String"}], "]"}], ":=",
  RowBox[{"Module", "[",
   RowBox[{
    RowBox[{"{",
     RowBox[{"lines", ",", "stripped", ",", "content", ",", "parsed"}],
     "}"}], ",",
    RowBox[{
     RowBox[{"If", "[",
      RowBox[{
       RowBox[{"!",
        RowBox[{"FileExistsQ", "[", "path", "]"}]}], ",",
       RowBox[{
        RowBox[{"Message", "[",
         RowBox[{
          RowBox[{"LoadDotEnv", "::", "nofile"}], ",", "path"}],
         "]"}], ";",
        RowBox[{"Return", "[", "$Failed", "]"}]}]}], "]"}], ";",
     RowBox[{"lines", "=",
      RowBox[{
       RowBox[{"StringTrim", "/@"}],
       RowBox[{"ReadList", "[", "path", ",", "String", "]"}]}]}], ";",
     RowBox[{"lines", "=",
      RowBox[{
       RowBox[{
        RowBox[{"StringDelete", "[",
         RowBox[{"#", ",", "\"\<\\\"\>\""}], "]"}], "&"}], "/@",
       "lines"}]}], ";",
     RowBox[{"stripped", "=",
      RowBox[{"Select", "[",
       RowBox[{"lines", ",",
        RowBox[{
         RowBox[{
          RowBox[{"!",
           RowBox[{"StringStartsQ", "[",
            RowBox[{"#", ",", "\"\<#\>\""}], "]"}]}], "&&",
          RowBox[{"#", "=!=", "\"\<\>\""}]}], "&"}]}], "]"}]}], ";",
     RowBox[{"If", "[",
      RowBox[{
       RowBox[{"stripped", "===",
        RowBox[{"{", "}"}]}], ",",
       RowBox[{"Return", "[",
        RowBox[{"\[LeftAssociation]", "\[RightAssociation]"}], "]"}]}],
      "]"}], ";",
     RowBox[{"content", "=",
      RowBox[{"StringRiffle", "[",
       RowBox[{"stripped", ",", "\"\<\n\>\""}], "]"}]}], ";",
     RowBox[{"parsed", "=",
      RowBox[{"ImportString", "[",
       RowBox[{"content", ",", "\"\<Ini\>\""}], "]"}]}], ";",
     RowBox[{"Association", "@@",
      RowBox[{"Flatten", "[",
       RowBox[{"Values", "[", "parsed", "]"}], "]"}]}]}]}], "]"}]}]],
 "Input",
 CellID->100000006,ExpressionUUID->"a1000001-0001-0001-0001-000000000006"],

Cell[BoxData[
 RowBox[{
  RowBox[{"LoadDotEnv", "::", "nofile"}], "=",
  "\"\<File not found: `1`.\>\""}]], "Input",
 CellID->100000007,ExpressionUUID->"a1000001-0001-0001-0001-000000000007"]

}, Open  ]],

