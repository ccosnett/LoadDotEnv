Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"LoadDotEnv", "[", "]"}], " ", "Loads", " ", "environment", " ",
       "variables", " ", 
      RowBox[{"from", " ", ".", "env"}], " ", "files", " ", "into", " ", "a", 
      " ", "Wolfram", " ", "Language", " ", 
      RowBox[{"session", ".", " ", "Handles"}], " ", "the", " ", "basic", " ", 
      RowBox[{"case", ":", " ", "key"}]}], "=", 
     RowBox[{"value", " ", "pairs", " ", 
      RowBox[{"(", 
       RowBox[{"quoted", " ", "or", " ", "unquoted"}], ")"}]}]}], ",", 
    RowBox[{"comment", " ", "lines"}], ",", " ", 
    RowBox[{"blank", " ", 
     RowBox[{"lines", ".", " ", "No"}], " ", "support", " ", "yet", " ", 
     RowBox[{"for", ":", " ", 
      RowBox[{"multi", "-", 
       RowBox[{"line", " ", "values"}]}]}]}], ",", 
    RowBox[{"variable", " ", "expansion"}], ",", 
    RowBox[{"the", " ", "`export`", " ", "prefix"}], ",", " ", 
    RowBox[{
     RowBox[{"or", " ", "UTF"}], "-", 
     RowBox[{"8", " ", "BOM", " ", 
      RowBox[{"stripping", ".", " ", "Parsing"}], " ", 
      RowBox[{"strategy", ":", " ", 
       RowBox[{"strip", " ", "comment", " ", "lines", " ", 
        RowBox[{"(", 
         RowBox[{"starting", " ", "with", " ", "#"}], ")"}], " ", "and", " ", 
        "blank", " ", "lines"}]}]}]}], ",", 
    RowBox[{
     RowBox[{"then", " ", "delegate", " ", "key"}], "=", 
     RowBox[{"value", " ", "parsing", " ", "to", " ", 
      RowBox[{"ImportString", "[", 
       RowBox[{"...", ",", "\"\<Ini\>\""}], "]"}]}]}], ",", 
    RowBox[{
     RowBox[{
     "which", " ", "treats", " ", "the", " ", "content", " ", "as", " ", "an",
       " ", "INI"}], "-", 
     RowBox[{"style", " ", 
      RowBox[{"file", ".", "This"}], " ", "avoids", " ", "reimplementing", 
      " ", "what", " ", "the", " ", "built"}], "-", 
     RowBox[{"in", " ", "importer", " ", "already", " ", "does", " ", 
      RowBox[{"correctly", "."}]}]}]}], "\n", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "LoadDotEnv", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"LoadDotEnv", "::", "usage"}], " ", "=", " ", 
     "\"\<LoadDotEnv[] loads the .env file in the current working directory \
and returns an Association of key-value pairs.\nLoadDotEnv[path] loads the \
.env file at the given path.\>\""}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"LoadDotEnv", "[", "]"}], " ", ":=", " ", 
    RowBox[{"LoadDotEnv", "[", 
     RowBox[{"FileNameJoin", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Directory", "[", "]"}], ",", " ", "\"\<.env\>\""}], "}"}], 
      "]"}], "]"}]}], "\n", "\n", 
   RowBox[{
    RowBox[{"LoadDotEnv", "[", "path_String", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "lines", ",", " ", "stripped", ",", " ", "content", ",", " ", 
        "parsed"}], "}"}], ",", " ", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", " ", 
          RowBox[{"FileExistsQ", "[", "path", "]"}]}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{
           "ResourceFunction", "[", "\"\<ResourceFunctionMessage\>\"", "]"}], 
           "[", 
           RowBox[{
            RowBox[{"LoadDotEnv", "::", "nofile"}], ",", " ", "path"}], "]"}],
           ";", "\n", "   ", 
          RowBox[{"Return", "[", "$Failed", "]"}]}]}], "]"}], ";", "\n", "  ", 
       RowBox[{"lines", " ", "=", " ", 
        RowBox[{"StringTrim", " ", "/@", " ", 
         RowBox[{"ReadList", "[", 
          RowBox[{"path", ",", " ", "String"}], "]"}]}]}], ";", "\n", "  ", 
       RowBox[{"lines", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"StringDelete", "[", 
           RowBox[{"#", ",", " ", "\"\<\\\"\>\""}], "]"}], " ", "&"}], " ", "/@",
          " ", "lines"}]}], ";", "\n", "  ", 
       RowBox[{"stripped", " ", "=", " ", 
        RowBox[{"Select", "[", 
         RowBox[{"lines", ",", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"!", " ", 
             RowBox[{"StringStartsQ", "[", 
              RowBox[{"#", ",", " ", "\"\<#\>\""}], "]"}]}], " ", "&&", " ", 
            RowBox[{"#", " ", "=!=", " ", "\"\<\>\""}]}], " ", "&"}]}], 
         "]"}]}], ";", "\n", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"stripped", " ", "===", " ", 
          RowBox[{"{", "}"}]}], ",", " ", 
         RowBox[{"Return", "[", 
          RowBox[{"<|", "|>"}], "]"}]}], "]"}], ";", "\n", "  ", 
       RowBox[{"content", " ", "=", " ", 
        RowBox[{"StringRiffle", "[", 
         RowBox[{"stripped", ",", " ", "\"\<\\n\>\""}], "]"}]}], ";", "\n", 
       "  ", 
       RowBox[{"parsed", " ", "=", " ", 
        RowBox[{"ImportString", "[", 
         RowBox[{"content", ",", " ", "\"\<Ini\>\""}], "]"}]}]}]}], "\n", 
     "  ", "]"}]}], "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"LoadDotEnv", "::", "nofile"}], " ", "=", " ", 
     "\"\<File not found: `1`.\>\""}], ";"}]}]}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.982046433654572*^9, 3.9820465691512337`*^9}, {
  3.982046655798472*^9, 3.982046655823271*^9}, {3.982047031337163*^9, 
  3.98204703980266*^9}, {3.9820471167235937`*^9, 3.9820471171981363`*^9}, {
  3.9820479081051207`*^9, 3.982047925896905*^9}, {3.982050366405205*^9, 
  3.982050383866988*^9}, {3.982050429996622*^9, 3.98205043309429*^9}, {
  3.982051162210475*^9, 3.9820511753222513`*^9}},
 CellTags->"DefaultContent",
