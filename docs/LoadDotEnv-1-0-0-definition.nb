Cell[BoxData[
 RowBox[{"AssociationQ", "[", 
  RowBox[{
   RowBox[{"file", "=", 
    RowBox[{"Export", "[", 
     RowBox[{
      RowBox[{"FileNameJoin", "[", 
       RowBox[{"{", 
        RowBox[{"$TemporaryDirectory", ",", "\"\<.env\>\""}], "}"}], "]"}], 
      ",", "\"\<# database config\\nDB_HOST=localhost\\n\\nDB_PORT=5432\>\"", 
      ",", "\"\<Text\>\""}], "]"}]}], ";", "\n", 
   RowBox[{"LoadDotEnv", "[", "file", "]"}]}], "]"}]], "Input",
